# Sao chép file này thành .env trên EC2:
# cp .env.example .env
# nano .env

# ── Database (RDS) ──────────────────────────────────────────
export DATABASE_URL=jdbc:postgresql://YOUR_RDS_ENDPOINT:5432/taskoryx
export DATABASE_USERNAME=postgres
export DATABASE_PASSWORD=YOUR_DB_PASSWORD

# ── JWT ─────────────────────────────────────────────────────
# Tạo secret ngẫu nhiên: openssl rand -hex 32
export JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# ── Mail (Gmail App Password) ────────────────────────────────
export MAIL_USERNAME=your_gmail@gmail.com
export MAIL_PASSWORD=your_16_char_app_password

# ── CORS ────────────────────────────────────────────────────
export FRONTEND_URL=https://your-frontend-domain.com
export CORS_ORIGIN_1=https://your-frontend-domain.com
export CORS_ORIGIN_2=https://www.your-frontend-domain.com

# ── Paths ───────────────────────────────────────────────────
export UPLOAD_DIR=/home/ubuntu/taskoryx-backend/uploads
export LOG_FILE=/home/ubuntu/taskoryx-backend/logs/taskoryx.log
