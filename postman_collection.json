                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Name updated\", () => pm.expect(pm.response.json().data.name).to.eql('Newman Project Updated'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Sprints",
      "item": [
        {
          "name": "Create Sprint",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/sprints" },
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Sprint 1\",\"goal\":\"Deliver MVP\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                  "const data = pm.response.json().data;",
                  "pm.test(\"Status is PLANNED\", () => pm.expect(data.status).to.eql('PLANNED'));",
                  "pm.environment.set('sprint_id', data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List Sprints",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/sprints" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Returns array\", () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Start Sprint",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/sprints/{{sprint_id}}/start" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Status is ACTIVE\", () => pm.expect(pm.response.json().data.status).to.eql('ACTIVE'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Start Sprint - Already Active (400)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const baseUrl = pm.collectionVariables.get('base_url');",
                  "const projectId = pm.environment.get('project_id');",
                  "const token = pm.environment.get('access_token');",
                  "pm.sendRequest({",
                  "  url: baseUrl + '/projects/' + projectId + '/sprints',",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },",
                  "  body: { mode: 'raw', raw: JSON.stringify({ name: 'Sprint Conflict' }) }",
                  "}, (err, res) => {",
                  "  pm.environment.set('conflict_sprint_id', res.json().data.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 400 — cannot start while another is ACTIVE\", () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/sprints/{{conflict_sprint_id}}/start" }
          }
        },
        {
          "name": "Complete Sprint",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/sprints/{{sprint_id}}/complete" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Status is COMPLETED\", () => pm.expect(pm.response.json().data.status).to.eql('COMPLETED'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
