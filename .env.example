# ==================== DATABASE ====================
DATABASE_URL=jdbc:postgresql://localhost:5432/taskoryx
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_db_password

# ==================== JWT ====================
# Tạo secret ngẫu nhiên: openssl rand -hex 32
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# ==================== MAIL (Gmail App Password) ====================
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_char_app_password

# ==================== FRONTEND / CORS ====================
FRONTEND_URL=https://your-frontend-domain.com
CORS_ORIGIN_1=https://your-frontend-domain.com
CORS_ORIGIN_2=https://www.your-frontend-domain.com

# ==================== STORAGE ====================
# Đặt false để lưu file local trên EC2 (không cần S3)
# Đặt true nếu dùng AWS S3 (cần điền phần S3 bên dưới)
USE_S3=false
UPLOAD_DIR=/home/ubuntu/taskoryx-backend/uploads

# ==================== S3 (chỉ cần nếu USE_S3=true) ====================
S3_BUCKET=your-bucket-name
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_PUBLIC_BASE_URL=https://your-bucket.s3.ap-southeast-1.amazonaws.com

# ==================== AI (tùy chọn) ====================
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
# OPENAI_API_KEY=your_openai_api_key

# ==================== LOGGING ====================
LOG_FILE=/home/ubuntu/taskoryx-backend/logs/taskoryx.log
